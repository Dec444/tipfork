# --- OpenAI (used by menu extract + translation; optional for visuals if VISUAL_PROVIDER=qwen) ---
OPENAI_API_KEY=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
OPENAI_TEXT_MODEL=gpt-4.1
OPENAI_TRANSLATE_MODEL=gpt-4.1-mini
OPENAI_IMAGE_MODEL=gpt-image-1

# --- Visual generation provider ---
# qwen | openai | auto
VISUAL_PROVIDER=qwen

# --- Qwen / DashScope image generation ---
# You can set either QWEN_API_KEY or DASHSCOPE_API_KEY.
QWEN_API_KEY=sk-ws-H.YXYXLD.UZj0.MEUCIQDN7e4PB-FlEe7TVIdWyfYy3aQkdKGYDk3cvlwpw13QfwIgYJFx_58X-Kng2oENDUAhVzBo8zcem7dtKBJm8pvTEbI
