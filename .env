# Prefer setting workspace id + region, unless you want to provide a full endpoint directly.
QWEN_WORKSPACE_ID=ws-1wrnllby1pisut87
QWEN_REGION=ap-southeast-1
# Optional explicit endpoint override:
QWEN_IMAGE_ENDPOINT=

# qwen-turbo is text-only; use an image-capable model for visuals.
QWEN_IMAGE_MODEL=qwen-image-2.0
QWEN_TEXT_MODEL=qwen-turbo
QWEN_TEXT_ENDPOINT=https://dashscope-intl.aliyuncs.com/compatible-mode/v1/chat/completions
